{
  "name": "design-auditor",
  "version": "1.0.0",
  "private": true,
  "description": "Figma plugin for automated design system QA powered by Claude",
  "scripts": {
    "build:plugin": "esbuild plugin/code.ts --bundle --outfile=plugin/code.js --target=es2020 --format=iife",
    "watch:plugin": "esbuild plugin/code.ts --bundle --outfile=plugin/code.js --target=es2020 --format=iife --watch",
    "vercel-build": "echo 'Serverless functions built by Vercel'",
    "build": "npm run build:plugin && tsc --project tsconfig.json",
    "dev": "vercel dev"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.104.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.5",
    "@vercel/node": "^5.0.0",
    "dotenv": "^17.3.1",
    "esbuild": "^0.24.0",
    "express": "^5.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vercel": "^50.28.0"
  }
}
